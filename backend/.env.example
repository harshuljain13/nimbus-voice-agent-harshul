# Copy to ../.env (repo root) or backend/.env and fill in. Keys can also be supplied
# per-request from the frontend (stored in the browser, sent as X-*-Key headers).
OPENAI_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=

# RAG embedding/rerank profile:
#   light = OpenAI embeddings + LLM rerank (no torch, Railway-friendly) [default]
#   rich  = local sentence-transformers + cross-encoder (needs sentence-transformers)
EMBEDDING_PROFILE=light
